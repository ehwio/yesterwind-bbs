# Copy this to .env and fill in real values — never commit .env

# Database (default: SQLite)
# For PostgreSQL: postgresql+asyncpg://user:password@host:5432/bbsdb
# For MySQL:      mysql+aiomysql://user:password@host:3306/bbsdb
DATABASE_URL=sqlite+aiosqlite:///data/bbs.db

# BBS identity
BBS_NAME=Yesterwind BBS
BBS_SYSOP=Sysop
BBS_HOSTNAME=localhost

# Network
BBS_PORT=23
BBS_MAX_CONNECTIONS=64

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# Sysop account (set on first run; change immediately)
SYSOP_PASSWORD=change-me
